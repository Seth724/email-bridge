# Groq AI Configuration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail IMAP Configuration
# Get app passwords from: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_gmail_address_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993

# Telegram Bot Configuration
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Schedule Configuration (UTC timezone)
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
TIMEZONE=UTC

# LangSmith Configuration (Optional - for tracing)
# Get API key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=email-bridge

# Deployment Mode (standalone, mcp-local, mcp-remote)
DEPLOYMENT_MODE=standalone


t.me/sethna_email_bot
