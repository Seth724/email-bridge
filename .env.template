
# Email Bridge - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Groq AI Configuration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail IMAP Configuration
# Get app password from: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993

# Telegram Bot Configuration
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Schedule Configuration (UTC timezone)
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
TIMEZONE=UTC

# LangSmith Configuration (Optional - for tracing AI decisions)
# Get API key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=email-bridge

# Custom Rules Configuration
USE_CUSTOM_RULES=true
RULES_FILE=config/rules.ini

# Time-Based Urgency (Optional - don't disturb during these hours)
QUIET_HOURS_START=22  # 10 PM
QUIET_HOURS_END=7     # 7 AM
WEEKEND_MODE=silent   # Options: silent, normal, urgent_only

# Deployment Mode (standalone, mcp-local, mcp-remote)
DEPLOYMENT_MODE=standalone
